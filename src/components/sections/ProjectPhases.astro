---
import { phases } from '../../data/project-content';
---

<section
  id="fases"
  class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 bg-mist/50"
  aria-labelledby="titulo-fases"
>
  <h2 id="titulo-fases" class="text-3xl sm:text-4xl font-bold text-tech-slate mb-10">
    Fases del proyecto
  </h2>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8" role="list">
    {phases.map((phase) => (
      <article
        role="listitem"
        class={`relative rounded-xl bg-surface p-6 border-l-4 ${phase.borderClass} shadow-sm`}
      >
        <p class="text-sm font-medium uppercase tracking-wider text-hydro-teal">
          {phase.label}
        </p>
        <h3 class="mt-2 text-xl font-semibold text-tech-slate">
          {phase.title}
        </h3>
        <p class="mt-1 text-sm text-muted/80">{phase.period}</p>
        <p class="mt-3 text-muted leading-relaxed">
          {phase.description}
        </p>
      </article>
    ))}
  </div>
</section>
