---
import { objectiveGeneral, pillars } from '../../data/project-content';
---

<section
  id="objetivos"
  class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8 sm:py-10"
  aria-labelledby="titulo-objetivos"
>
  <header class="max-w-3xl mb-8">
    <h2 id="titulo-objetivos" class="text-3xl sm:text-4xl font-bold text-tech-slate text-balance">
      Objetivos del proyecto
    </h2>
    <p class="mt-4 text-lg text-muted leading-relaxed text-pretty">
      {objectiveGeneral}
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" role="list">
    {pillars.map((pillar) => (
      <article
        role="listitem"
        class="rounded-xl bg-surface border border-gray-200/80 p-6 shadow-sm motion-safe:transition-[box-shadow,border-color] motion-safe:duration-200 hover:border-demeter-green/30 hover:shadow-md"
      >
        <h3 class={`text-xl font-semibold ${pillar.accentClass}`}>
          {pillar.title}
        </h3>
        <p class="mt-3 text-muted leading-relaxed">
          {pillar.description}
        </p>
      </article>
    ))}
  </div>
</section>
