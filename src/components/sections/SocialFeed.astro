---
// ZERO-JS EXCEPTION: third-party Instagram widget (Elfsight | Curator.io | SnapWidget)
// Account: @ies_gsr | Hashtag filter: #demeteria (configure in provider panel)
import { instagramPosts, socialFeedConfig } from '../../data/project-content';

const WIDGET_ID = import.meta.env.PUBLIC_SOCIAL_WIDGET_ID ?? '';
const WIDGET_PROVIDER = import.meta.env.PUBLIC_SOCIAL_WIDGET_PROVIDER ?? 'elfsight';

const envPostUrls = [
  import.meta.env.PUBLIC_INSTAGRAM_POST_URL,
  ...(import.meta.env.PUBLIC_INSTAGRAM_POSTS?.split(',').map((s: string) => s.trim()) ?? []),
].filter(Boolean) as string[];

const curatedPosts = [
  ...instagramPosts,
  ...envPostUrls.map((permalink) => ({ permalink })),
].filter(
  (post, index, arr) => arr.findIndex((p) => p.permalink === post.permalink) === index,
);

const { instagramUrl, hashtag } = socialFeedConfig;
const hasWidget = Boolean(WIDGET_ID);
const hasNativeEmbeds = curatedPosts.length > 0;
---

<section
  id="redes-sociales"
  class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16"
  aria-labelledby="titulo-social"
>
  <header class="mb-8">
    <h2 id="titulo-social" class="text-3xl sm:text-4xl font-bold text-tech-slate">
      DemeterIA en Instagram
    </h2>
    <p class="mt-3 text-muted">
      Publicaciones de{' '}
      <a
        href={instagramUrl}
        class="text-hydro-teal hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-hydro-teal focus-visible:ring-offset-2 rounded-sm"
        rel="noopener noreferrer"
        target="_blank"
      >
        @{socialFeedConfig.account}
      </a>{' '}
      con{' '}
      <span class="font-medium text-tech-slate">#{hashtag}</span>
    </p>
  </header>

  <div
    id="social-feed-widget"
    class="min-h-[320px] rounded-xl bg-surface border border-gray-200/80 overflow-hidden"
    aria-label="Publicaciones de Instagram del proyecto DemeterIA"
    aria-live="polite"
  >
    {hasWidget ? (
      WIDGET_PROVIDER === 'snapwidget' ? (
        <>
          {/* ZERO-JS EXCEPTION: SnapWidget iframe — filter @ies_gsr + #demeteria in panel */}
          <iframe
            src={`https://snapwidget.com/embed/${WIDGET_ID}`}
            title="Feed de Instagram @ies_gsr — #demeteria"
            class="w-full min-h-[400px] border-0"
            allowtransparency="true"
            scrolling="no"
            loading="lazy"
          />
        </>
      ) : WIDGET_PROVIDER === 'curator' ? (
        <>
          {/* ZERO-JS EXCEPTION: Curator.io — filter @ies_gsr + #demeteria in panel */}
          <div id="curator-feed-default-feed-container" />
          <script is:inline define:vars={{ feedId: WIDGET_ID }}>
            (function () {
              var i, e, d = document;
              i = d.createElement('script');
              i.async = 1;
              i.src = 'https://cdn.curator.io/published/' + feedId + '.js';
              e = d.getElementsByTagName('script')[0];
              e.parentNode.insertBefore(i, e);
            })();
          </script>
        </>
      ) : (
        <>
          {/* ZERO-JS EXCEPTION: Elfsight (default) — filter @ies_gsr + #demeteria in panel */}
          <div class={`elfsight-app-${WIDGET_ID}`} />
          <script is:inline src="https://elfsightcdn.com/platform.js" async />
        </>
      )
    ) : hasNativeEmbeds ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-4 sm:p-6 justify-items-center">
        {curatedPosts.map((post) => (
          <blockquote
            class="instagram-media w-full max-w-[540px]"
            data-instgrm-captioned
            data-instgrm-permalink={`${post.permalink}?utm_source=ig_embed&utm_campaign=loading`}
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:12px; margin:0; max-width:540px; min-width:326px; padding:0; width:100%;"
          >
            <a
              href={post.permalink}
              rel="noopener noreferrer"
              target="_blank"
              class="block p-8 text-center text-muted hover:text-hydro-teal"
            >
              {post.label ?? 'Ver publicación en Instagram'}
            </a>
          </blockquote>
        ))}
      </div>
    ) : (
      <div class="p-6 sm:p-10 max-w-lg mx-auto">
        <p class="text-center text-muted leading-relaxed">
          El feed dinámico de Instagram requiere configurar un widget gratuito.
          Sigue la guía en <code class="text-xs bg-mist px-1 rounded">docs/instagram-feed-setup.md</code>.
        </p>
        <ol class="mt-6 text-sm text-muted space-y-2 list-decimal list-inside">
          <li>Crea un widget en <a href="https://elfsight.com/instagram-feed-instashow/" class="text-hydro-teal hover:underline" rel="noopener noreferrer" target="_blank">Elfsight</a> (plan gratuito).</li>
          <li>Conecta la cuenta <strong class="text-tech-slate">@ies_gsr</strong>.</li>
          <li>Filtra por hashtag <strong class="text-tech-slate">#demeteria</strong>.</li>
          <li>Copia el ID del widget y créalo en <code class="text-xs bg-mist px-1 rounded">.env</code>:</li>
        </ol>
        <pre class="mt-3 p-3 rounded-lg bg-mist text-xs text-tech-slate overflow-x-auto"><code>PUBLIC_SOCIAL_WIDGET_ID=tu-widget-id
PUBLIC_SOCIAL_WIDGET_PROVIDER=elfsight</code></pre>
        <p class="mt-4 text-center">
          <a
            href={instagramUrl}
            class="text-hydro-teal font-medium hover:underline"
            rel="noopener noreferrer"
            target="_blank"
          >
            Mientras tanto, ver @ies_gsr en Instagram →
          </a>
        </p>
      </div>
    )}
  </div>

  {hasNativeEmbeds && (
    <script is:inline async src="https://www.instagram.com/embed.js" />
  )}

  <p class="mt-4 text-sm text-muted">
    <a
      href={instagramUrl}
      class="text-hydro-teal hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-hydro-teal focus-visible:ring-offset-2 rounded-sm"
      rel="noopener noreferrer"
      target="_blank"
    >
      @{socialFeedConfig.account} en Instagram
    </a>
    {' '}— publicaciones con <span class="font-medium text-tech-slate">#{hashtag}</span>
  </p>

  <noscript>
    <p class="mt-4 text-sm text-muted">
      <a href={instagramUrl} rel="noopener noreferrer" target="_blank">
        Ver @{socialFeedConfig.account} en Instagram
      </a>
      {' '}— busca #{hashtag}
    </p>
  </noscript>
</section>
