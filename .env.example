# Instagram — opción A: embed nativo de publicaciones concretas (recomendado para empezar)
# Copia el enlace desde Instagram (⋯ → Copiar enlace) de la publicación del 20 de mayo u otras con #demeteria
PUBLIC_INSTAGRAM_POST_URL=https://www.instagram.com/p/SHORTCODE/

# Varias publicaciones (separadas por coma)
# PUBLIC_INSTAGRAM_POSTS=https://www.instagram.com/p/AAA/,https://www.instagram.com/p/BBB/

# Instagram — opción B: widget dinámico Curator.io o Elfsight
# Cuenta @ies_gsr, filtro hashtag #demeteria (configurar en el panel del proveedor)
# PUBLIC_SOCIAL_WIDGET_ID=tu-feed-id
# PUBLIC_SOCIAL_WIDGET_PROVIDER=curator
