# Feed dinámico Instagram (@ies_gsr, hashtag #demeteria)
# Guía completa: docs/instagram-feed-setup.md

# Elfsight (recomendado) — ID del widget tras crearlo en elfsight.com
PUBLIC_SOCIAL_WIDGET_ID=
PUBLIC_SOCIAL_WIDGET_PROVIDER=elfsight

# Alternativas: curator | snapwidget
# PUBLIC_SOCIAL_WIDGET_PROVIDER=curator

# Opcional: embeds nativos de publicaciones concretas (no se actualizan solos)
# PUBLIC_INSTAGRAM_POST_URL=https://www.instagram.com/p/SHORTCODE/
